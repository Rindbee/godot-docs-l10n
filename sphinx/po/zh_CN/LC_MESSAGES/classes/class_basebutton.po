#: ../../docs/classes/class_basebutton.rst:113
msgid ""
"**DRAW_NORMAL** = **0** --- The normal state (i.e. not pressed, not "
"hovered, not toggled and enabled) of buttons."
msgstr "**DRAW_NORMAL** = **0** —— 按钮的正常状态（即未按下、未悬停、未切换和启用）。"

#: ../../docs/classes/class_basebutton.rst:115
msgid "**DRAW_PRESSED** = **1** --- The state of buttons are pressed."
msgstr "**DRAW_PRESSED** = **1** —— 按钮的状态是按下的。"

#: ../../docs/classes/class_basebutton.rst:117
msgid "**DRAW_HOVER** = **2** --- The state of buttons are hovered."
msgstr "**DRAW_HOVER** = **2** —— 按钮的状态是悬停的。"

#: ../../docs/classes/class_basebutton.rst:119
msgid "**DRAW_DISABLED** = **3** --- The state of buttons are disabled."
msgstr "**DRAW_DISABLED** = **3** —— 按钮的状态是禁用的。"

#: ../../docs/classes/class_basebutton.rst:121
#, fuzzy
msgid ""
"**DRAW_HOVER_PRESSED** = **4** --- The state of buttons are both hovered "
"and pressed."
msgstr "**DRAW_HOVER** = **2** —— 按钮的状态是悬停的。"

#: ../../docs/classes/class_basebutton.rst:131
msgid "enum **ActionMode**:"
msgstr "枚举 **ActionMode**："

#: ../../docs/classes/class_basebutton.rst:133
msgid ""
"**ACTION_MODE_BUTTON_PRESS** = **0** --- Require just a press to consider"
" the button clicked."
msgstr "**ACTION_MODE_BUTTON_PRESS** = **0** —— 只需按一下即可认为按钮被点击。"

#: ../../docs/classes/class_basebutton.rst:135
msgid ""
"**ACTION_MODE_BUTTON_RELEASE** = **1** --- Require a press and a "
"subsequent release before considering the button clicked."
msgstr "**ACTION_MODE_BUTTON_RELEASE** = **1** —— 在认为按钮被点击之前，需要按一下并随后释放它。"

