#: ../../docs/classes/class_generic6dofjoint.rst:264
msgid "enum **Param**:"
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:266
msgid ""
"**PARAM_LINEAR_LOWER_LIMIT** = **0** --- The minimum difference between "
"the pivot points' axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:268
msgid ""
"**PARAM_LINEAR_UPPER_LIMIT** = **1** --- The maximum difference between "
"the pivot points' axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:270
msgid ""
"**PARAM_LINEAR_LIMIT_SOFTNESS** = **2** --- A factor applied to the "
"movement across the axes. The lower, the slower the movement."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:272
msgid ""
"**PARAM_LINEAR_RESTITUTION** = **3** --- The amount of restitution on the"
" axes' movement. The lower, the more momentum gets lost."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:274
msgid ""
"**PARAM_LINEAR_DAMPING** = **4** --- The amount of damping that happens "
"at the linear motion across the axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:276
msgid ""
"**PARAM_LINEAR_MOTOR_TARGET_VELOCITY** = **5** --- The velocity the "
"linear motor will try to reach."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:278
msgid ""
"**PARAM_LINEAR_MOTOR_FORCE_LIMIT** = **6** --- The maximum force the "
"linear motor will apply while trying to reach the velocity target."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:280
msgid ""
"**PARAM_ANGULAR_LOWER_LIMIT** = **10** --- The minimum rotation in "
"negative direction to break loose and rotate around the axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:282
msgid ""
"**PARAM_ANGULAR_UPPER_LIMIT** = **11** --- The minimum rotation in "
"positive direction to break loose and rotate around the axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:284
msgid ""
"**PARAM_ANGULAR_LIMIT_SOFTNESS** = **12** --- The speed of all rotations "
"across the axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:286
msgid ""
"**PARAM_ANGULAR_DAMPING** = **13** --- The amount of rotational damping "
"across the axes. The lower, the more dampening occurs."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:288
msgid ""
"**PARAM_ANGULAR_RESTITUTION** = **14** --- The amount of rotational "
"restitution across the axes. The lower, the more restitution occurs."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:290
msgid ""
"**PARAM_ANGULAR_FORCE_LIMIT** = **15** --- The maximum amount of force "
"that can occur, when rotating around the axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:292
msgid ""
"**PARAM_ANGULAR_ERP** = **16** --- When rotating across the axes, this "
"error tolerance factor defines how much the correction gets slowed down. "
"The lower, the slower."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:294
msgid ""
"**PARAM_ANGULAR_MOTOR_TARGET_VELOCITY** = **17** --- Target speed for the"
" motor at the axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:296
msgid ""
"**PARAM_ANGULAR_MOTOR_FORCE_LIMIT** = **18** --- Maximum acceleration for"
" the motor at the axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:298
msgid ""
"**PARAM_MAX** = **22** --- Represents the size of the :ref:`Param "
"<enum_Generic6DOFJoint_Param>` enum."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:318
msgid "enum **Flag**:"
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:320
msgid ""
"**FLAG_ENABLE_LINEAR_LIMIT** = **0** --- If enabled, linear motion is "
"possible within the given limits."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:322
msgid ""
"**FLAG_ENABLE_ANGULAR_LIMIT** = **1** --- If enabled, rotational motion "
"is possible within the given limits."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:324
msgid "**FLAG_ENABLE_LINEAR_SPRING** = **3**"
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:326
msgid "**FLAG_ENABLE_ANGULAR_SPRING** = **2**"
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:328
msgid ""
"**FLAG_ENABLE_MOTOR** = **4** --- If enabled, there is a rotational motor"
" across these axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:330
msgid ""
"**FLAG_ENABLE_LINEAR_MOTOR** = **5** --- If enabled, there is a linear "
"motor across these axes."
msgstr ""

#: ../../docs/classes/class_generic6dofjoint.rst:332
msgid ""
"**FLAG_MAX** = **6** --- Represents the size of the :ref:`Flag "
