msgid "enum **TextureType**:"
msgstr ""

#: ../../docs/classes/class_visualshadernodecubemap.rst:59
msgid "**TYPE_DATA** = **0** --- No hints are added to the uniform declaration."
msgstr ""

#: ../../docs/classes/class_visualshadernodecubemap.rst:61
msgid ""
"**TYPE_COLOR** = **1** --- Adds ``hint_albedo`` as hint to the uniform "
"declaration for proper sRGB to linear conversion."
msgstr ""

#: ../../docs/classes/class_visualshadernodecubemap.rst:63
msgid ""
"**TYPE_NORMALMAP** = **2** --- Adds ``hint_normal`` as hint to the "
"uniform declaration, which internally converts the texture for proper "
"usage as normal map."
msgstr ""

