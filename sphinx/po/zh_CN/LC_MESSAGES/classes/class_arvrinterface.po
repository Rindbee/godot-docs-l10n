#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:77
msgid "enum **Capabilities**:"
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:79
msgid "**ARVR_NONE** = **0** --- No ARVR capabilities."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:81
msgid ""
"**ARVR_MONO** = **1** --- This interface can work with normal rendering "
"output (non-HMD based AR)."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:83
msgid ""
"**ARVR_STEREO** = **2** --- This interface supports stereoscopic "
"rendering."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:85
msgid ""
"**ARVR_AR** = **4** --- This interface supports AR (video background and "
"real world tracking)."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:87
msgid ""
"**ARVR_EXTERNAL** = **8** --- This interface outputs to an external "
"device. If the main viewport is used, the on screen output is an "
"unmodified buffer of either the left or right eye (stretched if the "
"viewport size is not changed to the same aspect ratio of "
":ref:`get_render_targetsize "
"<class_ARVRInterface_method_get_render_targetsize>`). Using a separate "
"viewport node frees up the main viewport for other purposes."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:99
msgid "enum **Eyes**:"
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:101
msgid ""
"**EYE_MONO** = **0** --- Mono output, this is mostly used internally when"
" retrieving positioning information for our camera node or when stereo "
"scopic rendering is not supported."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:103
msgid ""
"**EYE_LEFT** = **1** --- Left eye output, this is mostly used internally "
"when rendering the image for the left eye and obtaining positioning and "
"projection information."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:105
msgid ""
"**EYE_RIGHT** = **2** --- Right eye output, this is mostly used "
"internally when rendering the image for the right eye and obtaining "
"positioning and projection information."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:121
msgid "enum **Tracking_status**:"
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:123
msgid "**ARVR_NORMAL_TRACKING** = **0** --- Tracking is behaving as expected."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:125
msgid ""
"**ARVR_EXCESSIVE_MOTION** = **1** --- Tracking is hindered by excessive "
"motion (the player is moving faster than tracking can keep up)."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:127
msgid ""
"**ARVR_INSUFFICIENT_FEATURES** = **2** --- Tracking is hindered by "
"insufficient features, it's too dark (for camera-based tracking), player "
"is blocked, etc."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:129
msgid ""
"**ARVR_UNKNOWN_TRACKING** = **3** --- We don't know the status of the "
"tracking or this interface does not provide feedback."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_arvrinterface.rst:131
msgid ""
"**ARVR_NOT_TRACKING** = **4** --- Tracking is not functional (camera not "
"plugged in or obscured, lighthouses turned off, etc.)."
msgstr ""

