msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_networkedmultiplayerpeer.rst:126
msgid "**CONNECTION_CONNECTING** = **1** --- A connection attempt is ongoing."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_networkedmultiplayerpeer.rst:128
msgid "**CONNECTION_CONNECTED** = **2** --- The connection attempt succeeded."
msgstr ""

