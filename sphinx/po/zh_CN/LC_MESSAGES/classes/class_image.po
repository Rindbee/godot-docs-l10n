#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:240
msgid "**FORMAT_RGB565** = **7**"
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:242
msgid ""
"**FORMAT_RF** = **8** --- OpenGL texture format ``GL_R32F`` where there's"
" one component, a 32-bit floating-point value."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:244
msgid ""
"**FORMAT_RGF** = **9** --- OpenGL texture format ``GL_RG32F`` where there"
" are two components, each a 32-bit floating-point values."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:246
msgid ""
"**FORMAT_RGBF** = **10** --- OpenGL texture format ``GL_RGB32F`` where "
"there are three components, each a 32-bit floating-point values."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:248
msgid ""
"**FORMAT_RGBAF** = **11** --- OpenGL texture format ``GL_RGBA32F`` where "
"there are four components, each a 32-bit floating-point values."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:250
msgid ""
"**FORMAT_RH** = **12** --- OpenGL texture format ``GL_R32F`` where "
"there's one component, a 16-bit \"half-precision\" floating-point value."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:252
msgid ""
"**FORMAT_RGH** = **13** --- OpenGL texture format ``GL_RG32F`` where "
"there are two components, each a 16-bit \"half-precision\" floating-point"
" value."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:254
msgid ""
"**FORMAT_RGBH** = **14** --- OpenGL texture format ``GL_RGB32F`` where "
"there are three components, each a 16-bit \"half-precision\" floating-"
"point value."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:256
msgid ""
"**FORMAT_RGBAH** = **15** --- OpenGL texture format ``GL_RGBA32F`` where "
"there are four components, each a 16-bit \"half-precision\" floating-"
"point value."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:258
msgid ""
"**FORMAT_RGBE9995** = **16** --- A special OpenGL texture format where "
"the three color components have 9 bits of precision and all three share a"
" single 5-bit exponent."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:260
msgid ""
"**FORMAT_DXT1** = **17** --- The `S3TC "
"<https://en.wikipedia.org/wiki/S3_Texture_Compression>`_ texture format "
"that uses Block Compression 1, and is the smallest variation of S3TC, "
"only providing 1 bit of alpha and color data being premultiplied with "
"alpha."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:264
msgid ""
"**FORMAT_DXT3** = **18** --- The `S3TC "
"<https://en.wikipedia.org/wiki/S3_Texture_Compression>`_ texture format "
"that uses Block Compression 2, and color data is interpreted as not "
"having been premultiplied by alpha. Well suited for images with sharp "
"alpha transitions between translucent and opaque areas."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:268
msgid ""
"**FORMAT_DXT5** = **19** --- The `S3TC "
"<https://en.wikipedia.org/wiki/S3_Texture_Compression>`_ texture format "
"also known as Block Compression 3 or BC3 that contains 64 bits of alpha "
"channel data followed by 64 bits of DXT1-encoded color data. Color data "
"is not premultiplied by alpha, same as DXT3. DXT5 generally produces "
"superior results for transparent gradients compared to DXT3."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:272
msgid ""
"**FORMAT_RGTC_R** = **20** --- Texture format that uses `Red Green "
"Texture Compression "
"<https://www.khronos.org/opengl/wiki/Red_Green_Texture_Compression>`_, "
"normalizing the red channel data using the same compression algorithm "
"that DXT5 uses for the alpha channel."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:274
msgid ""
"**FORMAT_RGTC_RG** = **21** --- Texture format that uses `Red Green "
"Texture Compression "
"<https://www.khronos.org/opengl/wiki/Red_Green_Texture_Compression>`_, "
"normalizing the red and green channel data using the same compression "
"algorithm that DXT5 uses for the alpha channel."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:276
msgid ""
"**FORMAT_BPTC_RGBA** = **22** --- Texture format that uses `BPTC "
"<https://www.khronos.org/opengl/wiki/BPTC_Texture_Compression>`_ "
"compression with unsigned normalized RGBA components."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:280
msgid ""
"**FORMAT_BPTC_RGBF** = **23** --- Texture format that uses `BPTC "
"<https://www.khronos.org/opengl/wiki/BPTC_Texture_Compression>`_ "
"compression with signed floating-point RGB components."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:282
msgid ""
"**FORMAT_BPTC_RGBFU** = **24** --- Texture format that uses `BPTC "
"<https://www.khronos.org/opengl/wiki/BPTC_Texture_Compression>`_ "
"compression with unsigned floating-point RGB components."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:284
msgid ""
"**FORMAT_PVRTC2** = **25** --- Texture format used on PowerVR-supported "
"mobile platforms, uses 2-bit color depth with no alpha. More information "
"can be found `here <https://en.wikipedia.org/wiki/PVRTC>`_."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:288
msgid ""
"**FORMAT_PVRTC2A** = **26** --- Same as `PVRTC2 "
"<https://en.wikipedia.org/wiki/PVRTC>`_, but with an alpha component."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:290
msgid ""
"**FORMAT_PVRTC4** = **27** --- Similar to `PVRTC2 "
"<https://en.wikipedia.org/wiki/PVRTC>`_, but with 4-bit color depth and "
"no alpha."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:292
msgid ""
"**FORMAT_PVRTC4A** = **28** --- Same as `PVRTC4 "
"<https://en.wikipedia.org/wiki/PVRTC>`_, but with an alpha component."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:294
msgid ""
"**FORMAT_ETC** = **29** --- `Ericsson Texture Compression format 1 "
"<https://en.wikipedia.org/wiki/Ericsson_Texture_Compression#ETC1>`_, also"
" referred to as \"ETC1\", and is part of the OpenGL ES graphics standard."
" This format cannot store an alpha channel."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:296
msgid ""
"**FORMAT_ETC2_R11** = **30** --- `Ericsson Texture Compression format 2 "
"<https://en.wikipedia.org/wiki/Ericsson_Texture_Compression#ETC2_and_EAC>`_"
" (``R11_EAC`` variant), which provides one channel of unsigned data."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:298
msgid ""
"**FORMAT_ETC2_R11S** = **31** --- `Ericsson Texture Compression format 2 "
"<https://en.wikipedia.org/wiki/Ericsson_Texture_Compression#ETC2_and_EAC>`_"
" (``SIGNED_R11_EAC`` variant), which provides one channel of signed data."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:300
msgid ""
"**FORMAT_ETC2_RG11** = **32** --- `Ericsson Texture Compression format 2 "
"<https://en.wikipedia.org/wiki/Ericsson_Texture_Compression#ETC2_and_EAC>`_"
" (``RG11_EAC`` variant), which provides two channels of unsigned data."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:302
msgid ""
"**FORMAT_ETC2_RG11S** = **33** --- `Ericsson Texture Compression format 2"
" "
"<https://en.wikipedia.org/wiki/Ericsson_Texture_Compression#ETC2_and_EAC>`_"
" (``SIGNED_RG11_EAC`` variant), which provides two channels of signed "
"data."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:304
msgid ""
"**FORMAT_ETC2_RGB8** = **34** --- `Ericsson Texture Compression format 2 "
"<https://en.wikipedia.org/wiki/Ericsson_Texture_Compression#ETC2_and_EAC>`_"
" (``RGB8`` variant), which is a follow-up of ETC1 and compresses RGB888 "
"data."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:308
msgid ""
"**FORMAT_ETC2_RGBA8** = **35** --- `Ericsson Texture Compression format 2"
" "
"<https://en.wikipedia.org/wiki/Ericsson_Texture_Compression#ETC2_and_EAC>`_"
" (``RGBA8``\\ variant), which compresses RGBA8888 data with full alpha "
"support."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:312
msgid ""
"**FORMAT_ETC2_RGB8A1** = **36** --- `Ericsson Texture Compression format "
"2 "
"<https://en.wikipedia.org/wiki/Ericsson_Texture_Compression#ETC2_and_EAC>`_"
" (``RGB8_PUNCHTHROUGH_ALPHA1`` variant), which compresses RGBA data to "
"make alpha either fully transparent or fully opaque."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_image.rst:316
msgid "**FORMAT_ETC2_RA_AS_RG** = **37**"
msgstr ""

