#~ "**ARRAY_VERTEX** = **0** --- "
#~ ":ref:`PoolVector3Array <class_PoolVector3Array>`, "
#~ ":ref:`PoolVector2Array <class_PoolVector2Array>`, or "
#~ ":ref:`Array <class_Array>` of vertex "
#~ "positions."
#~ msgstr ""

#~ msgid ""
#~ "**ARRAY_NORMAL** = **1** --- "
#~ ":ref:`PoolVector3Array <class_PoolVector3Array>` of "
#~ "vertex normals."
#~ msgstr ""

#~ msgid ""
#~ "**ARRAY_TANGENT** = **2** --- "
#~ ":ref:`PoolRealArray <class_PoolRealArray>` of vertex"
#~ " tangents. Each element in groups of"
#~ " 4 floats, first 3 floats determine"
#~ " the tangent, and the last the "
#~ "binormal direction as -1 or 1."
#~ msgstr ""

#~ msgid ""
#~ "**ARRAY_COLOR** = **3** --- "
#~ ":ref:`PoolColorArray <class_PoolColorArray>` of "
#~ "vertex colors."
#~ msgstr ""

#~ msgid ""
#~ "**ARRAY_TEX_UV** = **4** --- "
#~ ":ref:`PoolVector2Array <class_PoolVector2Array>` for "
#~ "UV coordinates."
#~ msgstr ""

#~ msgid ""
#~ "**ARRAY_TEX_UV2** = **5** --- "
#~ ":ref:`PoolVector2Array <class_PoolVector2Array>` for "
#~ "second UV coordinates."
#~ msgstr ""

#~ msgid ""
#~ "**ARRAY_BONES** = **6** --- "
#~ ":ref:`PoolRealArray <class_PoolRealArray>` or "
#~ ":ref:`PoolIntArray <class_PoolIntArray>` of bone "
#~ "indices. Each element in groups of "
#~ "4 floats."
#~ msgstr ""

#~ msgid ""
#~ "**ARRAY_WEIGHTS** = **7** --- "
#~ ":ref:`PoolRealArray <class_PoolRealArray>` of bone"
#~ " weights. Each element in groups of"
#~ " 4 floats."
#~ msgstr ""

#~ msgid ""
#~ "**ARRAY_INDEX** = **8** --- :ref:`PoolIntArray"
#~ " <class_PoolIntArray>` of integers used as"
#~ " indices referencing vertices, colors, "
#~ "normals, tangents, and textures. All of"
#~ " those arrays must have the same "
#~ "number of elements as the vertex "
#~ "array. No index can be beyond the"
#~ " vertex array size. When this index"
#~ " array is present, it puts the "
#~ "function into \"index mode,\" where the"
#~ " index selects the \\*i\\*'th vertex, "
#~ "normal, tangent, color, UV, etc. This"
#~ " means if you want to have "
#~ "different normals or colors along an "
#~ "edge, you have to duplicate the "
#~ "vertices."
#~ msgstr ""

