msgid "NodePath"
msgstr "NodePath"

#: ../../docs/classes/class_nodepath.rst:12
msgid "Pre-parsed scene tree path."
msgstr "预解析的场景树路径。"

#: ../../docs/classes/class_nodepath.rst:15
