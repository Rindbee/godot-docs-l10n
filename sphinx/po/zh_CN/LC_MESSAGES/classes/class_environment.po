#: ../../docs/classes/class_environment.rst:283
msgid "enum **GlowBlendMode**:"
msgstr ""

#: ../../docs/classes/class_environment.rst:285
msgid ""
"**GLOW_BLEND_MODE_ADDITIVE** = **0** --- Additive glow blending mode. "
"Mostly used for particles, glows (bloom), lens flare, bright sources."
msgstr ""

#: ../../docs/classes/class_environment.rst:287
msgid ""
"**GLOW_BLEND_MODE_SCREEN** = **1** --- Screen glow blending mode. "
"Increases brightness, used frequently with bloom."
msgstr ""

#: ../../docs/classes/class_environment.rst:289
msgid ""
"**GLOW_BLEND_MODE_SOFTLIGHT** = **2** --- Soft light glow blending mode. "
"Modifies contrast, exposes shadows and highlights (vivid bloom)."
msgstr ""

#: ../../docs/classes/class_environment.rst:291
msgid ""
"**GLOW_BLEND_MODE_REPLACE** = **3** --- Replace glow blending mode. "
"Replaces all pixels' color by the glow value. This can be used to "
"simulate a full-screen blur effect by tweaking the glow parameters to "
"match the original image's brightness."
msgstr ""

#: ../../docs/classes/class_environment.rst:293
msgid "**GLOW_BLEND_MODE_MIX** = **4**"
msgstr ""

#: ../../docs/classes/class_environment.rst:307
msgid "enum **ToneMapper**:"
msgstr ""

#: ../../docs/classes/class_environment.rst:309
msgid ""
"**TONE_MAPPER_LINEAR** = **0** --- Linear tonemapper operator. Reads the "
"linear data and passes it on unmodified."
msgstr ""

#: ../../docs/classes/class_environment.rst:311
msgid ""
"**TONE_MAPPER_REINHARDT** = **1** --- Reinhardt tonemapper operator. "
"Performs a variation on rendered pixels' colors by this formula: ``color "
"= color / (1 + color)``."
msgstr ""

#: ../../docs/classes/class_environment.rst:313
msgid "**TONE_MAPPER_FILMIC** = **2** --- Filmic tonemapper operator."
msgstr ""

#: ../../docs/classes/class_environment.rst:315
msgid ""
"**TONE_MAPPER_ACES** = **3** --- Academy Color Encoding System tonemapper"
" operator."
msgstr ""

