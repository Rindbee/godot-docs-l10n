msgid "PackedInt64Array"
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_packedint64array.rst:12
msgid "A packed :ref:`Array <class_Array>` of 64-bit integers."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_packedint64array.rst:15
msgid "Description"
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_packedint64array.rst:17
msgid ""
"An :ref:`Array <class_Array>` specifically designed to hold 64-bit "
"integer values. Packs data tightly, so it saves memory for large array "
"sizes."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_packedint64array.rst:19
msgid "**Note:** This type is passed by value and not by reference."
msgstr ""

#: /home/bee/code/godot/godot-docs-l10n/docs/classes/class_packedint64array.rst:21
msgid ""
"**Note:** This type stores signed 64-bit integers, which means it can "
"take values in the interval ``[-2^63, 2^63 - 1]``, i.e. "
"``[-9223372036854775808, 9223372036854775807]``. Exceeding those bounds "
"will wrap around. If you only need to pack 32-bit integers tightly, see "
":ref:`PackedInt32Array <class_PackedInt32Array>` for a more memory-"
"friendly alternative."
msgstr ""

