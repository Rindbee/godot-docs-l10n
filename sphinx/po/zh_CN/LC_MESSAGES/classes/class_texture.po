#~ msgid "enum **Flags**:"
#~ msgstr "枚举 **Flags**："

#~ msgid ""
#~ "**FLAGS_DEFAULT** = **7** --- Default "
#~ "flags. :ref:`FLAG_MIPMAPS "
#~ "<class_Texture_constant_FLAG_MIPMAPS>`, :ref:`FLAG_REPEAT "
#~ "<class_Texture_constant_FLAG_REPEAT>` and "
#~ ":ref:`FLAG_FILTER <class_Texture_constant_FLAG_FILTER>` "
#~ "are enabled."
#~ msgstr ""
#~ "**FLAGS_DEFAULT** = **7** —— 默认标志。启用 "
#~ ":ref:`FLAG_MIPMAPS "
#~ "<class_Texture_constant_FLAG_MIPMAPS>`、:ref:`FLAG_REPEAT "
#~ "<class_Texture_constant_FLAG_REPEAT>` 和 :ref:`FLAG_FILTER"
#~ " <class_Texture_constant_FLAG_FILTER>`。"

#~ msgid ""
#~ "**FLAG_MIPMAPS** = **1** --- Generates "
#~ "mipmaps, which are smaller versions of"
#~ " the same texture to use when "
#~ "zoomed out, keeping the aspect ratio."
#~ msgstr ""
#~ "**FLAG_MIPMAPS** = **1** —— 生成 "
#~ "``mipmap``，该 ``mipmap`` 是缩小时使用的相同纹理的较小版本，并保持宽高比。"

#~ msgid ""
#~ "**FLAG_REPEAT** = **2** --- Repeats the"
#~ " texture (instead of clamp to edge)."
#~ msgstr "**FLAG_REPEAT** = **2** —— 重复纹理（而不是钳制到边缘）。"

#~ msgid ""
#~ "**FLAG_FILTER** = **4** --- Uses a "
#~ "magnifying filter, to enable smooth "
#~ "zooming in of the texture."
#~ msgstr "**FLAG_FILTER** = **4** —— 使用放大滤镜，以使纹理平滑放大。"

#~ msgid ""
#~ "**FLAG_ANISOTROPIC_FILTER** = **8** --- Uses"
#~ " anisotropic mipmap filtering. Generates "
#~ "smaller versions of the same texture "
#~ "with different aspect ratios."
#~ msgstr ""
#~ "**FLAG_ANISOTROPIC_FILTER** = **8** —— 使用各向异性的"
#~ " ``mipmap`` 过滤。生成具有不同纵横比的相同纹理的较小版本。"

#~ msgid ""
#~ "This results in better-looking textures"
#~ " when viewed from oblique angles."
#~ msgstr "从倾斜角度观看时，这会导致外观更好看。"

#~ msgid ""
#~ "**FLAG_CONVERT_TO_LINEAR** = **16** --- "
#~ "Converts the texture to the sRGB "
#~ "color space."
#~ msgstr "**FLAG_CONVERT_TO_LINEAR** = **16** —— 将纹理转换为sRGB颜色空间。"

#~ msgid ""
#~ "**FLAG_MIRRORED_REPEAT** = **32** --- Repeats"
#~ " the texture with alternate sections "
#~ "mirrored."
#~ msgstr "**FLAG_MIRRORED_REPEAT** = **32** —— 重复纹理并镜像其他部分。"

#~ msgid "**FLAG_VIDEO_SURFACE** = **2048** --- Texture is a video surface."
#~ msgstr "**FLAG_VIDEO_SURFACE** = **2048** —— 纹理是视频面。"

