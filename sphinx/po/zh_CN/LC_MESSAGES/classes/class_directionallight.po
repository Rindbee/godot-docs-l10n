#: ../../docs/classes/class_directionallight.rst:64
msgid "enum **ShadowMode**:"
msgstr ""

#: ../../docs/classes/class_directionallight.rst:66
msgid ""
"**SHADOW_ORTHOGONAL** = **0** --- Renders the entire scene's shadow map "
"from an orthogonal point of view. May result in blockier shadows on close"
" objects."
msgstr ""

#: ../../docs/classes/class_directionallight.rst:68
msgid ""
"**SHADOW_PARALLEL_2_SPLITS** = **1** --- Splits the view frustum in 2 "
"areas, each with its own shadow map."
msgstr ""

#: ../../docs/classes/class_directionallight.rst:70
msgid ""
"**SHADOW_PARALLEL_4_SPLITS** = **2** --- Splits the view frustum in 4 "
"areas, each with its own shadow map."
msgstr ""

#: ../../docs/classes/class_directionallight.rst:80
msgid "enum **ShadowDepthRange**:"
msgstr ""

#: ../../docs/classes/class_directionallight.rst:82
msgid ""
"**SHADOW_DEPTH_RANGE_STABLE** = **0** --- Keeps the shadow stable when "
"the camera moves, at the cost of lower effective shadow resolution."
msgstr ""

#: ../../docs/classes/class_directionallight.rst:84
msgid ""
"**SHADOW_DEPTH_RANGE_OPTIMIZED** = **1** --- Tries to achieve maximum "
"shadow resolution. May result in saw effect on shadow edges."
msgstr ""

