#~ msgid "enum **BlendMode**:"
#~ msgstr "枚举 **BlendMode**："

#~ msgid ""
#~ "**BLEND_MODE_MIX** = **0** --- Mix "
#~ "blending mode. Colors are assumed to "
#~ "be independent of the alpha (opacity)"
#~ " value."
#~ msgstr "**BLEND_MODE_MIX** = **0** —— 混合混合模式。假定颜色与alpha（不透明度）值无关。"

#~ msgid "**BLEND_MODE_ADD** = **1** --- Additive blending mode."
#~ msgstr "**BLEND_MODE_ADD** = **1** —— 相加混合模式。"

#~ msgid "**BLEND_MODE_SUB** = **2** --- Subtractive blending mode."
#~ msgstr "**BLEND_MODE_SUB** = **2** —— 相减混合模式。"

#~ msgid "**BLEND_MODE_MUL** = **3** --- Multiplicative blending mode."
#~ msgstr "**BLEND_MODE_MUL** = **3** —— 相乘混合模式。"

#~ msgid ""
#~ "**BLEND_MODE_PREMULT_ALPHA** = **4** --- Mix"
#~ " blending mode. Colors are assumed to"
#~ " be premultiplied by the alpha "
#~ "(opacity) value."
#~ msgstr "**BLEND_MODE_PREMULT_ALPHA** = **4** —— 混合混合模式。假定颜色已预先乘以alpha（不透明度）值。"

#~ msgid ""
#~ "**BLEND_MODE_DISABLED** = **5** --- Disables"
#~ " blending mode. Colors including alpha "
#~ "are written as-is. Only applicable "
#~ "for render targets with a transparent"
#~ " background. No lighting will be "
#~ "applied."
#~ msgstr ""
#~ "**BLEND_MODE_DISABLED** = **5** —— "
#~ "禁用混合模式。包括alpha的颜色均按原样书写。仅适用于具有透明背景的渲染目标。没有光线被应用。"

